{
  "$schema": "node_modules/wrangler/config/schema.json",
  "main": ".open-next/worker.js",
  "name": "mybcps",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "workers_dev": false,
  "observability": {
    "logs": {
      "enabled": true
    }
  }
}