    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "jose": "^6.0.11",
    "lucide-react": "^0.514.0",
    "ms": "^2.1.3",
    "next": "^15.3.5",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
