    "lucide-react": "^0.577.0",
    "ms": "^2.1.3",
    "next": "^16.1.7",
    "next-auth": "4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
