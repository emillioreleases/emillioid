    "drizzle-orm": "^0.44.5",
    "jose": "^6.1.0",
    "json-diff-ts": "^4.8.2",
    "lucide-react": "^0.514.0",
    "ms": "^2.1.3",
    "next": "^15.5.2",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.2",
